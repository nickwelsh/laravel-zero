{
    "name": "nickwelsh/laravel-zero",
    "description": "Define Zero queries and mutations once in Laravel",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/database": "^11.0||^12.0||^13.0",
        "illuminate/http": "^11.0||^12.0||^13.0",
        "illuminate/routing": "^11.0||^12.0||^13.0",
        "illuminate/validation": "^11.0||^12.0||^13.0",
        "nickwelsh/eloquent-zero": "dev-main",
        "nikic/php-parser": "^5.6",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^9.0||^10.0||^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "NickWelsh\\LaravelZero\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NickWelsh\\LaravelZero\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/nickwelsh/eloquent-zero"
        }
    ],
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {"pestphp/pest-plugin": true},
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": ["NickWelsh\\LaravelZero\\LaravelZeroServiceProvider"]
        },
        "zero": {"version": "1.8.0"}
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
